#include<stdio.h> 
#include<graphics.h> 
#include<conio.h> 
#include<math.h> 
void main(){ 
int gd=DETECT,gm,i,steps; 
float x1,y1,x2,y2,x,y,dx,dy; 
initgraph(&gd,&gm,"C:\\TURBOC3\\BGI"); 
scanf("%f%f%f%f",&x1,&y1,&x2,&y2); 
dx=x2-x1; dy=y2-y1; 
steps=(abs(dx)>abs(dy))?abs(dx):abs(dy); 
dx/=steps; dy/=steps; x=x1; y=y1; 
for(i=0;i<=steps;i++){ putpixel(x,y,WHITE); x+=dx; y+=dy; } 
getch(); closegraph(); 
} 
